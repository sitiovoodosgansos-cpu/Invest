rules_version = '2';

// Phase 2A rules for the Sitio Voo dos Gansos client-only app.
//
// These rules build on Phase 1 by tying WRITES to a real Firebase Auth
// admin account. Reads stay open because the app still filters data
// client-side (investor portals, direct-link portals, employee portals).
//
// DEPLOY ORDER MATTERS. Do NOT publish these rules before every admin has
// logged in at least once with the Phase 2 code, or the admin will lock
// themselves out of writes:
//
//   1. Deploy the Phase 2A app code. Legacy admin login still works because
//      the app falls back to the hashed /config/admin credential and then
//      transparently creates a Firebase Auth account + /users/{uid} doc.
//   2. Admin logs in once from the new build. This provisions Firebase Auth
//      and the /users/{uid} profile.
//   3. Publish THESE rules.
//
// Phase 2B (planned) will add a /shareTokens collection for revocable portal
// links and tighten /config/appData reads to authenticated callers only.

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the caller an authenticated admin, according to their
    // /users/{uid} profile? We rely on the profile doc because Firebase Auth
    // alone has no concept of roles.
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Main application data blob. The app serializes everything it persists
    // into this single doc. Reads stay public so investor / portal flows
    // keep working client-side; writes now require an authenticated admin.
    // This closes the Phase 1 gap where any anonymous client with a
    // valid-shape payload could overwrite the entire DB.
    match /config/appData {
      allow read: if true;

      allow create, update: if isAdmin()
        && request.resource != null
        && request.resource.data.keys().hasAll([
          'investors', 'birds', 'sales', 'expenses'
        ])
        && request.resource.data.investors is list
        && request.resource.data.birds is list
        && request.resource.data.sales is list
        && request.resource.data.expenses is list;

      allow delete: if false;
    }

    // Legacy admin credential document. Phase 2A still uses it as:
    //   - an adminExists signal on the login screen,
    //   - the source of truth for the admin username at login time,
    //   - the fallback hash verified during the first-login Firebase Auth
    //     migration.
    //
    // Create is still allowed on first-run setup. Updates require admin
    // Firebase Auth and must keep the hashed shape intact, so a leaked
    // session cookie can't downgrade the stored credential to plaintext.
    match /config/admin {
      allow read: if true;

      allow create: if !exists(/databases/$(database)/documents/config/admin)
        && request.resource.data.username is string
        && request.resource.data.username.size() > 0
        && request.resource.data.password is map
        && request.resource.data.password.algo == 'pbkdf2-sha256';

      allow update: if isAdmin()
        && request.resource.data.username is string
        && request.resource.data.password is map
        && request.resource.data.password.algo == 'pbkdf2-sha256'
        && request.resource.data.password.hash is string
        && request.resource.data.password.hash.size() == 64;

      allow delete: if false;
    }

    // Firebase Auth user profile. One doc per authenticated user, keyed by
    // uid. Holds the role ('admin' in Phase 2A, 'employee' / 'investor'
    // later). Users can self-create on first login as long as they stamp
    // their own uid and a minimal profile; updates and deletes stay
    // admin-only.
    match /users/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || isAdmin());

      allow create: if request.auth != null
        && request.auth.uid == uid
        && !exists(/databases/$(database)/documents/users/$(uid))
        && request.resource.data.role is string
        && request.resource.data.username is string;

      allow update, delete: if isAdmin();
    }

    // Phase 2B: revocable portal link tokens. Each document's ID IS the
    // token — we generate it with crypto.randomUUID() (128-bit unguessable).
    //
    //   /shareTokens/{tokenId}
    //     type:        'investor' | 'employee'
    //     investorId:  string (only when type == 'investor')
    //     createdAt:   ISO string
    //
    // GET is open: anyone holding a valid token can fetch the doc to
    // validate their portal link. Because UUIDs are random, there is no
    // meaningful way to enumerate — and LIST (collection query) is
    // explicitly admin-only so you cannot walk the collection.
    //
    // CREATE is admin-only and shape-checked. DELETE is admin-only. UPDATE
    // is forbidden — tokens are immutable; to "rotate" a token the admin
    // deletes the old doc and creates a new one.
    match /shareTokens/{tokenId} {
      allow get: if true;
      allow list: if isAdmin();

      allow create: if isAdmin()
        && request.resource.data.type in ['investor', 'employee']
        && request.resource.data.createdAt is string
        && (
          request.resource.data.type == 'employee'
          || (
            request.resource.data.type == 'investor'
            && request.resource.data.investorId is string
            && request.resource.data.investorId.size() > 0
          )
        );

      allow update: if false;
      allow delete: if isAdmin();
    }

    // Phase 2C: sales moved to their own collection.
    //
    // Sales used to live inside /config/appData as a single array. At ~1100
    // rows the monolithic doc started hitting the 1 MiB / ~20k index-entry
    // cap and silently rejected writes, causing lost imports and lost edits.
    // By promoting each sale to its own doc we lift that ceiling and also
    // make per-sale edits O(1) instead of rewriting the full array.
    //
    // Reads stay open (investor portals read sales client-side and filter by
    // matchedInvestorId; tightening this to authenticated-only is a Phase 2C+
    // change that also requires portals to signInAnonymously). Writes are
    // admin-only and shape-checked.
    match /sales/{saleId} {
      allow read: if true;

      allow create, update: if isAdmin()
        && request.resource.data.keys().hasAll(['itemDescription', 'totalValue'])
        && request.resource.data.itemDescription is string
        && request.resource.data.totalValue is number;

      allow delete: if isAdmin();
    }

    // Lock down everything else. Any new collections must be added
    // explicitly above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
